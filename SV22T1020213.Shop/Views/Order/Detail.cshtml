@using SV22T1020213.Models.Sales
@model SV22T1020213.Models.Sales.OrderViewInfo
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.OrderID}";
    var details = ViewBag.Details as List<SV22T1020213.Models.Sales.OrderDetailViewInfo>;
    decimal total = details?.Sum(x => x.TotalPrice) ?? 0;
}

<style>
    /* CSS đồng bộ tone Hồng Pastel - Cam đào */
    :root {
        --pastel-pink: #ffafbd;
        --pastel-peach: #ffc3a0;
        --rose-accent: #ff7eb3; /* Hồng đậm làm điểm nhấn */
        --text-dark: #5a4b4f; /* Chữ màu nâu xám cho sang */
    }

    /* Hero Section với Gradient (Phần đầu trang) */
    .hero-section {
        background: linear-gradient(135deg, var(--pastel-pink) 0%, var(--pastel-peach) 100%);
        padding: 80px 0;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(255, 175, 189, 0.3);
        margin-bottom: 50px;
    }

    /* Tiêu đề Section (Có gạch chân hồng) */
    .section-title {
        font-weight: 800;
        position: relative;
        padding-bottom: 15px;
        color: var(--text-dark);
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background: var(--rose-accent);
            border-radius: 4px;
        }

    /* Tiện ích bổ sung */
    .text-rose {
        color: var(--rose-accent) !important;
    }

    .btn-hero-custom {
        color: var(--rose-accent) !important;
    }

        .btn-hero-custom:hover {
            background-color: #f8f9fa;
            transform: scale(1.02);
        }
    .customer-sidebar {
        border-radius: 20px;
        overflow: hidden;
        border: none !important;
    }

        .customer-sidebar .list-group-item {
            color: #5a4b4f;
            border: none;
            padding: 15px 20px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(255, 126, 179, 0.05);
        }

            .customer-sidebar .list-group-item:hover {
                background-color: #fff0f3;
                color: #ff7eb3;
                padding-left: 25px;
            }

            .customer-sidebar .list-group-item.active {
                background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
                color: white;
                font-weight: 600;
                box-shadow: 0 5px 15px rgba(255, 175, 189, 0.4);
            }

    .modern-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(255, 126, 179, 0.1);
        overflow: hidden;
        background: #fff;
    }

    .pastel-header {
        background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
        color: white;
        padding: 16px 24px;
        border-bottom: none;
    }

    .table-pastel th {
        background-color: #fffafb !important;
        color: #5a4b4f;
        border-bottom: 2px solid #ffafbd;
        font-weight: 600;
    }

    .table-pastel td {
        vertical-align: middle;
        border-color: rgba(255, 126, 179, 0.1);
        color: #5a4b4f;
    }

    /* Box thông tin phụ */
    .info-box {
        background-color: #fffafb;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid rgba(255, 126, 179, 0.15);
        height: 100%;
        transition: all 0.3s;
    }

        .info-box:hover {
            box-shadow: 0 8px 20px rgba(255, 126, 179, 0.1);
            transform: translateY(-3px);
        }

        .info-box h6 {
            color: #ff7eb3;
            font-weight: 700;
            margin-bottom: 15px;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

    .text-rose {
        color: #ff7eb3 !important;
    }
</style>

<div class="row mb-5 mt-3">
    <div class="col-md-3 mb-4 mb-md-0">
        <div class="list-group customer-sidebar shadow-sm">
            <a href="@Url.Action("Profile", "ShopAccount")" class="list-group-item list-group-item-action">
                <i class="bi bi-person-heart me-2"></i> Thông tin cá nhân
            </a>
            <a href="@Url.Action("ChangePassword", "ShopAccount")" class="list-group-item list-group-item-action">
                <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
            </a>
            <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action active">
                <i class="bi bi-bag-heart me-2"></i> Đơn hàng của tôi
            </a>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card modern-card">
            <div class="card-header pastel-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-receipt-cutoff me-2"></i> Chi tiết đơn hàng #@Model.OrderID</h5>
                <span class="badge bg-white text-dark rounded-pill px-3 py-2 shadow-sm" style="color: #ff7eb3 !important;">
                    <i class="bi bi-calendar-event me-1"></i> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>
            <div class="card-body p-4 p-lg-5">

                @if (TempData["Success"] != null)
                {
                    <div class="alert bg-success text-white rounded-4 border-0 shadow-sm mb-4"><i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert bg-danger text-white rounded-4 border-0 shadow-sm mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]</div>
                }

                <div class="alert rounded-4 border-0 shadow-sm mb-4
                    @(Model.Status == OrderStatusEnum.Completed ? "bg-success text-white" :
                                           Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected ? "bg-danger text-white" :
                                           "bg-light text-dark")"
                     style="@(Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected ? "background-color: #fff0f3 !important; border: 1px dashed #ffafbd !important;" : "")">

                    <div class="d-flex align-items-center p-2">
                        <i class="bi @(Model.Status == OrderStatusEnum.Completed ? "bi-check-circle-fill" :
                                                                 Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected ? "bi-x-circle-fill" :
                                                                 "bi-hourglass-split") fs-2 me-3"
                           style="@(Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected ? "color: #ff7eb3;" : "")"></i>
                        <div>
                            <strong class="fs-5" style="@(Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected ? "color: #5a4b4f;" : "")">
                                Trạng thái: @Model.Status.GetDescription()
                            </strong>
                            @if (Model.FinishedTime.HasValue)
                            {
                                <div class="small mt-1 opacity-75" style="@(Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected ? "color: #5a4b4f;" : "")">
                                    <i class="bi bi-clock me-1"></i> Cập nhật lúc: @Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="info-box">
                            <h6><i class="bi bi-person-heart me-2"></i>Thông tin khách hàng</h6>
                            <p class="mb-1"><strong style="color: #5a4b4f;">@Model.CustomerName</strong></p>
                            <p class="mb-1"><i class="bi bi-telephone text-muted me-2"></i> @Model.CustomerPhone</p>
                            <p class="mb-1"><i class="bi bi-envelope text-muted me-2"></i> @Model.CustomerEmail</p>
                            <p class="mb-0"><i class="bi bi-geo-alt text-muted me-2"></i> @Model.CustomerAddress</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-box">
                            <h6><i class="bi bi-truck me-2"></i>Thông tin giao hàng</h6>
                            <p class="mb-1"><i class="bi bi-geo-alt text-muted me-2"></i> @Model.DeliveryAddress</p>
                            <p class="mb-1"><i class="bi bi-map text-muted me-2"></i> @Model.DeliveryProvince</p>
                            @if (!string.IsNullOrEmpty(Model.ShipperName))
                            {
                                <hr class="my-2 opacity-25" style="border-color: #ff7eb3;">
                                <p class="mb-0 mt-2 fw-medium" style="color: #ff7eb3;">
                                    <i class="bi bi-bicycle me-2"></i> Giao hàng: @Model.ShipperName<br>
                                    <i class="bi bi-telephone me-2"></i> LH: @Model.ShipperPhone
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold mb-3 mt-2 text-uppercase" style="color: #5a4b4f; letter-spacing: 0.5px;">
                    <i class="bi bi-bag-heart-fill text-rose me-2"></i> Sản phẩm đã đặt
                </h6>
                <div class="table-responsive rounded-4 border overflow-hidden mb-4" style="border-color: rgba(255, 126, 179, 0.2) !important;">
                    <table class="table table-hover table-pastel mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">ĐVT</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in details)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="~/images/products/@item.Photo" class="rounded-3 shadow-sm me-3" style="width: 55px; height: 55px; object-fit: cover; border: 1px solid rgba(255,126,179,0.1);">
                                            <span class="fw-medium">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Unit</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill px-3 py-2" style="background-color: #fff0f3; color: #ff7eb3; border: 1px solid #ffafbd;">
                                            @item.Quantity
                                        </span>
                                    </td>
                                    <td class="text-end">@item.SalePrice.ToString("#,##0") đ</td>
                                    <td class="text-end fw-bold text-rose">@item.TotalPrice.ToString("#,##0") đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: #fffafb;">
                            <tr>
                                <td colspan="4" class="text-end fw-bold" style="padding: 15px;">Tổng cộng:</td>
                                <td class="text-end fs-5 fw-bold text-rose" style="padding: 15px;">@total.ToString("#,##0") đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 pt-3 border-top" style="border-color: rgba(255, 126, 179, 0.1) !important;">
                    <a href="@Url.Action("Index")" class="btn btn-light rounded-pill px-4 py-2 shadow-sm fw-medium" style="color: #5a4b4f; border: 1px solid #dee2e6;">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                    </a>

                    @if (Model.Status == OrderStatusEnum.New)
                    {
                        <form method="post" asp-action="CancelOrderShop" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?')">
                            <input type="hidden" name="id" value="@Model.OrderID" />
                            <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2 fw-medium">
                                <i class="bi bi-x-circle me-1"></i> Hủy đơn hàng
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>