@using SV22T1020213.Models.Catalog
@{
    ViewData["Title"] = "Trang chủ - Long shop";
    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<style>
    /* Định nghĩa tone màu chủ đạo */
    :root {
        --pastel-pink: #ffafbd;
        --pastel-peach: #ffc3a0;
        --rose-accent: #ff7eb3; /* Hồng đậm làm điểm nhấn */
        --text-dark: #5a4b4f; /* Chữ màu nâu xám thay vì đen tuyền để hợp với hồng */
    }

    body {
        color: var(--text-dark);
    }

    /* Hero Section với Gradient Hồng Pastel - Cam Đào */
    .hero-section {
        background: linear-gradient(135deg, var(--pastel-pink) 0%, var(--pastel-peach) 100%);
        padding: 80px 0;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(255, 175, 189, 0.3);
        margin-bottom: 50px;
    }

    /* Card Danh Mục */
    .category-card {
        transition: all 0.3s ease;
        border-radius: 20px;
        background: #fff0f3; /* Nền hồng rất nhạt */
    }

        .category-card:hover {
            transform: translateY(-8px);
            background: #ffffff;
            box-shadow: 0 15px 30px rgba(255, 126, 179, 0.15) !important;
        }

    /* Card Sản Phẩm */
    .product-card {
        transition: all 0.4s ease;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255, 126, 179, 0.1);
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(255, 126, 179, 0.15) !important;
            border-color: var(--pastel-pink);
        }

    .img-wrapper {
        overflow: hidden;
    }

    .product-card .card-img-top {
        transition: transform 0.5s ease;
    }

    .product-card:hover .card-img-top {
        transform: scale(1.08);
    }

    /* Nút Mua - Nổi bật với màu Rose Accent */
    .btn-buy {
        border-radius: 30px;
        padding: 6px 20px;
        font-weight: 600;
        color: var(--rose-accent);
        border: 2px solid var(--rose-accent);
        transition: all 0.3s;
    }

        .btn-buy:hover {
            background-color: var(--rose-accent);
            border-color: var(--rose-accent);
            color: white;
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(255, 126, 179, 0.3);
        }

    /* Khối tính năng Slogan */
    .feature-box {
        transition: all 0.3s ease;
        border-radius: 20px;
        border: 1px solid rgba(255, 126, 179, 0.05);
        background: #fff;
    }

        .feature-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(255, 126, 179, 0.12);
            background-color: #fffafb !important;
        }

    /* Tiêu đề Section */
    .section-title {
        font-weight: 800;
        position: relative;
        padding-bottom: 15px;
        color: var(--text-dark);
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background: var(--rose-accent);
            border-radius: 4px;
        }

    /* Tiện ích màu sắc cho Icon */
    .text-rose {
        color: var(--rose-accent) !important;
    }

    .btn-hero-custom {
        color: var(--rose-accent) !important;
    }

        .btn-hero-custom:hover {
            background-color: #f8f9fa;
            transform: scale(1.02);
        }
</style>

<div class="hero-section text-white text-center mt-3">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3"> Long Shop</h1>
        <p class="lead mb-4 opacity-75 fw-medium">Khám phá những sản phẩm chất lượng cao với phong cách ngọt ngào</p>
        <div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg px-5 rounded-pill shadow-sm fw-bold btn-hero-custom">
                <i class="bi bi-bag-heart-fill me-2"></i> Mua sắm ngay
            </a>
        </div>
    </div>
</div>

<div class="container mb-5 mt-5">
    <h3 class="text-center section-title mb-5">Danh mục nổi bật</h3>
    <div class="row justify-content-center">
        @foreach (var cat in categories.Take(6))
        {
            <div class="col-lg-2 col-md-3 col-6 mb-4">
                <a href="@Url.Action("Index", "Product", new { categoryId = cat.CategoryID })" class="text-decoration-none">
                    <div class="card text-center border-0 category-card h-100 py-4">
                        <div class="card-body">
                            <i class="bi bi-stars fs-1 text-rose mb-3 d-block"></i>
                            <h6 class="mb-0 fw-bold" style="color: var(--text-dark);">@cat.CategoryName</h6>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<div class="container mt-5">
    <h2 class="text-center section-title mb-5">Sản phẩm nổi bật</h2>
    <div class="row">
        @foreach (var product in featuredProducts)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 bg-white product-card position-relative">
                    <div class="img-wrapper">
                        <img src="~/images/products/@(string.IsNullOrEmpty(product.Photo) ? "nophoto.png" : product.Photo)"
                             class="card-img-top" alt="@product.ProductName" style="height: 240px; object-fit: cover;">
                    </div>
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold fs-6 mb-2 text-truncate" title="@product.ProductName">@product.ProductName</h5>
                        <p class="card-text text-muted small flex-grow-1">
                            @(product.ProductDescription?.Length > 60 ? product.ProductDescription.Substring(0, 60) + "..." : product.ProductDescription)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold fs-5 text-rose">@product.Price.ToString("#,##0") đ</span>
                            <button class="btn btn-buy add-to-cart z-2" data-product-id="@product.ProductID">
                                <i class="bi bi-cart-plus-fill"></i> Mua
                            </button>
                        </div>
                    </div>
                    <a href="@Url.Action("Detail", "Product", new { id = product.ProductID })" class="stretched-link"></a>
                </div>
            </div>
        }
    </div>

    @if (featuredProducts.Count == 0)
    {
        <div class="alert text-center rounded-4 py-4 shadow-sm" style="background-color: #fff0f3; color: var(--rose-accent); border: 1px dashed var(--pastel-pink);">
            <i class="bi bi-emoji-smile fs-3 d-block mb-2"></i>
            <span class="fs-5 fw-medium">Hiện chưa có sản phẩm nào nổi bật.</span>
        </div>
    }
</div>

<div class="container mt-5 mb-5 pb-4">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="p-4 feature-box h-100 shadow-sm">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; background: #fff0f3;">
                    <i class="bi bi-box-seam-fill fs-2 text-rose"></i>
                </div>
                <h5 class="fw-bold">Giao hàng miễn phí</h5>
                <p class="text-muted mb-0">Cho mọi đơn hàng từ 500.000đ</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4 feature-box h-100 shadow-sm">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; background: #fff0f3;">
                    <i class="bi bi-arrow-through-heart-fill fs-2 text-rose"></i>
                </div>
                <h5 class="fw-bold">Đổi trả dễ dàng</h5>
                <p class="text-muted mb-0">Miễn phí đổi trả trong 30 ngày</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4 feature-box h-100 shadow-sm">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; background: #fff0f3;">
                    <i class="bi bi-shield-lock-fill fs-2 text-rose"></i>
                </div>
                <h5 class="fw-bold">Bảo mật thanh toán</h5>
                <p class="text-muted mb-0">An toàn tuyệt đối 100%</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.add-to-cart').click(function(e) {
                e.preventDefault();
                e.stopPropagation();

                var btn = $(this);
                var originalHtml = btn.html();

                btn.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>...');
                btn.prop('disabled', true);

                var productId = btn.data('product-id');

                $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: 1 })
                    .done(function(response) {
                        if (response.success) {
                            $('#cartCount').text(response.cartCount);
                            alert('Đã thêm sản phẩm vào giỏ hàng!');
                        } else {
                            alert(response.message || 'Không thể thêm vào giỏ hàng.');
                        }
                    })
                    .fail(function() {
                        alert('Có lỗi xảy ra kết nối, vui lòng thử lại sau.');
                    })
                    .always(function() {
                        btn.html(originalHtml);
                        btn.prop('disabled', false);
                    });
            });
        });
    </script>
}