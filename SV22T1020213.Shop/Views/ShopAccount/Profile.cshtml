@using SV22T1020213.Admin
@model SV22T1020213.Shop.Models.UpdateProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<style>
    /* CSS đồng bộ tone Hồng Pastel - Cam đào */
    :root {
        --pastel-pink: #ffafbd;
        --pastel-peach: #ffc3a0;
        --rose-accent: #ff7eb3; /* Hồng đậm làm điểm nhấn */
        --text-dark: #5a4b4f; /* Chữ màu nâu xám cho sang */
    }

    /* Hero Section với Gradient (Phần đầu trang) */
    .hero-section {
        background: linear-gradient(135deg, var(--pastel-pink) 0%, var(--pastel-peach) 100%);
        padding: 80px 0;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(255, 175, 189, 0.3);
        margin-bottom: 50px;
    }

    /* Tiêu đề Section (Có gạch chân hồng) */
    .section-title {
        font-weight: 800;
        position: relative;
        padding-bottom: 15px;
        color: var(--text-dark);
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background: var(--rose-accent);
            border-radius: 4px;
        }

    /* Tiện ích bổ sung */
    .text-rose {
        color: var(--rose-accent) !important;
    }

    .btn-hero-custom {
        color: var(--rose-accent) !important;
    }

        .btn-hero-custom:hover {
            background-color: #f8f9fa;
            transform: scale(1.02);
        }
    .customer-sidebar {
        border-radius: 20px;
        overflow: hidden;
        border: none !important;
    }

        .customer-sidebar .list-group-item {
            color: #5a4b4f;
            border: none;
            padding: 15px 20px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(255, 126, 179, 0.05);
        }

            .customer-sidebar .list-group-item:hover {
                background-color: #fff0f3;
                color: #ff7eb3;
                padding-left: 25px;
            }

            .customer-sidebar .list-group-item.active {
                background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
                color: white;
                font-weight: 600;
                box-shadow: 0 5px 15px rgba(255, 175, 189, 0.4);
            }

    .modern-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(255, 126, 179, 0.1);
        overflow: hidden;
        background: #fff;
    }

    .pastel-header {
        background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
        color: white;
        padding: 16px 24px;
        border-bottom: none;
    }

    .form-control, .form-select {
        border-color: #dee2e6;
        color: #5a4b4f;
        border-radius: 12px;
        padding: 10px 15px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #ff7eb3;
            box-shadow: 0 0 0 0.25rem rgba(255, 126, 179, 0.25);
        }

    .form-label {
        font-weight: 600;
        color: #5a4b4f;
        margin-bottom: 8px;
    }

    .btn-rose-gradient {
        background: linear-gradient(135deg, #ffafbd 0%, #ff7eb3 100%);
        color: white;
        border: none;
        transition: all 0.3s;
        border-radius: 30px;
        padding: 10px 25px;
        font-weight: 600;
    }

        .btn-rose-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255, 126, 179, 0.4);
            color: white;
        }
</style>

<div class="row mb-5">
    <div class="col-md-3 mb-4 mb-md-0">
        <div class="list-group customer-sidebar shadow-sm">
            <a href="@Url.Action("Profile")" class="list-group-item list-group-item-action active">
                <i class="bi bi-person-heart me-2"></i> Thông tin cá nhân
            </a>
            <a href="@Url.Action("ChangePassword")" class="list-group-item list-group-item-action">
                <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
            </a>
            <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action">
                <i class="bi bi-bag-heart me-2"></i> Đơn hàng của tôi
            </a>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card modern-card">
            <div class="card-header pastel-header">
                <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Cập nhật thông tin cá nhân</h5>
            </div>
            <div class="card-body p-4 p-md-5">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert bg-success text-white rounded-4 border-0 shadow-sm mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <form method="post" asp-action="Profile">
                    <input type="hidden" asp-for="CustomerID" />

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="CustomerName" class="form-label">Tên khách hàng</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4"><i class="bi bi-person text-muted"></i></span>
                                <input asp-for="CustomerName" class="form-control border-start-0" placeholder="Nhập tên của bạn..." />
                            </div>
                            <span asp-validation-for="CustomerName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="Email" class="form-label">Địa chỉ Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4"><i class="bi bi-envelope text-muted"></i></span>
                                <input asp-for="Email" class="form-control border-start-0" type="email" placeholder="example@gmail.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="ContactName" class="form-label">Tên giao dịch</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4"><i class="bi bi-building text-muted"></i></span>
                                <input asp-for="ContactName" class="form-control border-start-0" />
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4"><i class="bi bi-telephone text-muted"></i></span>
                                <input asp-for="Phone" class="form-control border-start-0" placeholder="0123 456 789" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Province" class="form-label">Tỉnh / Thành phố</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 rounded-start-4"><i class="bi bi-geo-alt text-muted"></i></span>
                            <select asp-for="Province" class="form-select border-start-0" asp-items="await SelectListHelper.Provinces()">
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label">Địa chỉ chi tiết</label>
                        <textarea asp-for="Address" class="form-control" rows="3" style="border-radius: 12px;" placeholder="Số nhà, Tên đường, Phường/Xã..."></textarea>
                    </div>

                    <hr class="my-4" style="border-color: rgba(255, 126, 179, 0.2);">

                    <div class="text-end">
                        <button type="submit" class="btn btn-rose-gradient">
                            <i class="bi bi-save me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>