@using SV22T1020213.Admin
@model SV22T1020213.Shop.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_Layout";
}

<style>
    /* CSS Hồng Pastel */
    :root {
        --pastel-pink: #ffafbd;
        --pastel-peach: #ffc3a0;
        --rose-accent: #ff7eb3; /* Hồng đậm làm điểm nhấn */
        --text-dark: #5a4b4f; /* Chữ màu nâu xám cho sang */
    }

    /* Hero Section với Gradient (Phần đầu trang) */
    .hero-section {
        background: linear-gradient(135deg, var(--pastel-pink) 0%, var(--pastel-peach) 100%);
        padding: 80px 0;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(255, 175, 189, 0.3);
        margin-bottom: 50px;
    }

    /* Tiêu đề Section (Có gạch chân hồng) */
    .section-title {
        font-weight: 800;
        position: relative;
        padding-bottom: 15px;
        color: var(--text-dark);
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background: var(--rose-accent);
            border-radius: 4px;
        }

    /* Tiện ích bổ sung */
    .text-rose {
        color: var(--rose-accent) !important;
    }

    .btn-hero-custom {
        color: var(--rose-accent) !important;
    }

        .btn-hero-custom:hover {
            background-color: #f8f9fa;
            transform: scale(1.02);
        }
    .modern-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(255, 126, 179, 0.1);
        overflow: hidden;
        background: #fff;
    }

    .pastel-header {
        background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
        color: white;
        padding: 20px 24px;
        border-bottom: none;
    }

    .form-control, .form-select {
        border-color: #dee2e6;
        color: #5a4b4f;
        border-radius: 12px;
        padding: 10px 15px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #ff7eb3;
            box-shadow: 0 0 0 0.25rem rgba(255, 126, 179, 0.25);
        }

    .form-label {
        font-weight: 600;
        color: #5a4b4f;
        margin-bottom: 8px;
    }

    .btn-rose-gradient {
        background: linear-gradient(135deg, #ffafbd 0%, #ff7eb3 100%);
        color: white;
        border: none;
        transition: all 0.3s;
        border-radius: 30px;
        padding: 12px 25px;
        font-weight: 600;
    }

        .btn-rose-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255, 126, 179, 0.4);
            color: white;
        }

    .text-rose {
        color: #ff7eb3 !important;
    }

    .link-rose {
        color: #ff7eb3;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
    }

        .link-rose:hover {
            color: #e86a9f;
            text-decoration: underline;
        }
</style>

<div class="row justify-content-center mb-5 mt-3">
    <div class="col-md-8">
        <div class="card modern-card">
            <div class="card-header pastel-header text-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill me-2"></i> Đăng ký tài khoản mới</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form method="post" asp-action="Register">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerName" class="form-label">Họ tên <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Nhập họ và tên..." />
                            <span asp-validation-for="CustomerName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ContactName" class="form-label">Tên giao dịch</label>
                            <input asp-for="ContactName" class="form-control" placeholder="Tên hiển thị (Tùy chọn)..." />
                            <div class="form-text small opacity-75">Để trống sẽ lấy theo Họ tên</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="example@mail.com" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" type="tel" placeholder="0123 456 789" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••" />
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text small opacity-75">Mật khẩu phải có ít nhất 6 ký tự</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Province" class="form-label">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                            <select asp-for="Province" class="form-select" asp-items="await SelectListHelper.Provinces()">
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                            </select>
                            <span asp-validation-for="Province" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="Address" class="form-label">Địa chỉ chi tiết</label>
                            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Số nhà, đường..."></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-rose-gradient w-100 fs-5 mt-2">
                        <i class="bi bi-check-circle-fill me-1"></i> Tạo tài khoản
                    </button>
                </form>

                <hr class="my-4" style="border-color: rgba(255, 126, 179, 0.2);" />

                <div class="text-center" style="color: #5a4b4f;">
                    Đã có tài khoản? <a asp-action="Login" class="link-rose ms-1">Đăng nhập ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}