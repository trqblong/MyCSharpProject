@{
    ViewData["Title"] = "Từ chối truy cập";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm border-danger">
            <div class="card-body py-5">
                <i class="bi bi-shield-exclamation text-danger" style="font-size: 80px;"></i>
                <h2 class="mt-3 text-danger">Từ chối truy cập</h2>
                <p class="lead">Bạn không có quyền truy cập vào trang này.</p>
                <p>Vui lòng đăng nhập với tài khoản có quyền phù hợp.</p>
                <div class="mt-4">
                    <a href="@Url.Action("Login")" class="btn btn-primary">Đăng nhập</a>
                    <a href="@Url.Action("Index", "ShopHome")" class="btn btn-secondary">Về trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>