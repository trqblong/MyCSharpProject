@using SV22T1020213.Models.Catalog
@using SV22T1020213.Models.Common
@model PagedResult<Product>
@{
    Layout = null; // Partial View không dùng Layout
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 bg-white p-3 rounded-pill shadow-sm">
    <h5 class="mb-0 ms-3 fw-bold" style="color: #5a4b4f;">
        Sản phẩm <span class="badge rounded-pill ms-1" style="background-color: #ffafbd; color: white;">@Model.RowCount</span>
    </h5>
    <div class="dropdown me-2">
        <button class="btn btn-light rounded-pill dropdown-toggle fw-medium px-4" type="button" data-bs-toggle="dropdown" style="border: 1px solid #dee2e6; color: #5a4b4f;">
            <i class="bi bi-sort-down me-1"></i> Sắp xếp
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-2">
            <li>
                <a class="dropdown-item py-2" href="javascript:;"
                   onclick="document.getElementById('hiddenSortOrder').value = 'newest'; paginationSearch(null, document.getElementById('formSearch'), 1);">
                    Mới nhất
                </a>
            </li>
            <li>
                <a class="dropdown-item py-2" href="javascript:;"
                   onclick="document.getElementById('hiddenSortOrder').value = 'price_asc'; paginationSearch(null, document.getElementById('formSearch'), 1);">
                    Giá thấp đến cao
                </a>
            </li>
            <li>
                <a class="dropdown-item py-2" href="javascript:;"
                   onclick="document.getElementById('hiddenSortOrder').value = 'price_desc'; paginationSearch(null, document.getElementById('formSearch'), 1);">
                    Giá cao đến thấp
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="row">
    @foreach (var product in Model.DataItems)
    {
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card h-100 bg-white product-card position-relative">
                <div class="img-wrapper">
                    <img src="~/images/products/@(string.IsNullOrEmpty(product.Photo) ? "nophoto.png" : product.Photo)"
                         class="card-img-top w-100" alt="@product.ProductName" style="height: 220px; object-fit: cover;">
                </div>
                <div class="card-body d-flex flex-column p-4">
                    <h6 class="card-title fw-bold mb-2 text-truncate" title="@product.ProductName" style="color: #5a4b4f;">@product.ProductName</h6>
                    <p class="card-text text-muted small flex-grow-1" style="line-height: 1.5;">
                        @(product.ProductDescription?.Length > 60 ? product.ProductDescription.Substring(0, 60) + "..." : product.ProductDescription)
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top" style="border-color: rgba(255, 126, 179, 0.1) !important;">
                        <span class="fw-bold fs-5" style="color: #ff7eb3;">@product.Price.ToString("#,##0") đ</span>
                        <button class="btn btn-buy add-to-cart z-2 px-3" data-product-id="@product.ProductID" style="position: relative;">
                            <i class="bi bi-cart-plus"></i> Mua
                        </button>
                    </div>
                </div>
                <a href="@Url.Action("Detail", "Product", new { id = product.ProductID })" class="stretched-link"></a>
            </div>
        </div>
    }
</div>

@if (Model.DataItems.Count == 0)
{
    <div class="alert text-center rounded-4 py-5 shadow-sm mt-4" style="background-color: #fff0f3; border: 1px dashed #ffafbd;">
        <i class="bi bi-emoji-frown fs-1 d-block mb-3" style="color: #ff7eb3;"></i>
        <h5 class="fw-bold" style="color: #5a4b4f;">Không tìm thấy sản phẩm nào!</h5>
        <p class="text-muted mb-0">Vui lòng thử lại với từ khóa hoặc bộ lọc khác.</p>
    </div>
}

@if (Model.PageCount > 1)
{
    <nav class="mt-5 mb-4">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link shadow-sm fw-medium" href="javascript:;">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <a class="page-link shadow-sm fw-medium" href="javascript:;">...</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link shadow-sm fw-medium"
                           href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>
}