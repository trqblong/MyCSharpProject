@model SV22T1020213.Shop.Models.ProductSearchViewModel
@{
    ViewData["Title"] = "Sản phẩm";
}

<style>
    /* Định dạng màu trực tiếp của bạn */
    :root {
        --pastel-pink: #ffafbd;
        --pastel-peach: #ffc3a0;
        --rose-accent: #ff7eb3; /* Hồng đậm làm điểm nhấn */
        --text-dark: #5a4b4f; /* Chữ màu nâu xám cho sang */
    }

    /* Hero Section với Gradient (Phần đầu trang) */
    .hero-section {
        background: linear-gradient(135deg, var(--pastel-pink) 0%, var(--pastel-peach) 100%);
        padding: 80px 0;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(255, 175, 189, 0.3);
        margin-bottom: 50px;
    }

    /* Tiêu đề Section (Có gạch chân hồng) */
    .section-title {
        font-weight: 800;
        position: relative;
        padding-bottom: 15px;
        color: var(--text-dark);
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background: var(--rose-accent);
            border-radius: 4px;
        }

    /* Tiện ích bổ sung */
    .text-rose {
        color: var(--rose-accent) !important;
    }

    .btn-hero-custom {
        color: var(--rose-accent) !important;
    }

        .btn-hero-custom:hover {
            background-color: #f8f9fa;
            transform: scale(1.02);
        }
    .modern-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(255, 126, 179, 0.1);
        overflow: hidden;
        background: #fff;
    }

    .pastel-header {
        background: linear-gradient(135deg, #ffafbd 0%, #ffc3a0 100%);
        color: white;
        padding: 16px 20px;
        border-bottom: none;
    }

    .form-control:focus, .form-select:focus {
        border-color: #ff7eb3;
        box-shadow: 0 0 0 0.25rem rgba(255, 126, 179, 0.25);
    }

    .btn-search-pastel {
        background-color: #ff7eb3;
        color: white;
        border-radius: 30px;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
    }

        .btn-search-pastel:hover {
            background-color: #e86a9f;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 126, 179, 0.4);
        }

    .product-card {
        transition: all 0.4s ease;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255, 126, 179, 0.1);
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(255, 126, 179, 0.15);
            border-color: #ffafbd;
        }

        .product-card .card-img-top {
            transition: transform 0.5s ease;
        }

        .product-card:hover .card-img-top {
            transform: scale(1.08);
        }

    .img-wrapper {
        overflow: hidden;
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }

    .btn-buy {
        border-radius: 30px;
        padding: 6px 20px;
        font-weight: 600;
        color: #ff7eb3;
        border: 2px solid #ff7eb3;
        transition: all 0.3s;
        background: transparent;
    }

        .btn-buy:hover {
            background-color: #ff7eb3;
            border-color: #ff7eb3;
            color: white;
            transform: scale(1.05);
        }

    .pagination .page-link {
        color: #ff7eb3;
        border-radius: 50%;
        margin: 0 4px;
        border: none;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pagination .page-item.active .page-link {
        background-color: #ff7eb3;
        color: white;
        box-shadow: 0 4px 10px rgba(255, 126, 179, 0.3);
    }
</style>

<div class="mb-5">
    <div class="card modern-card mb-4">
        <div class="card-header pastel-header">
            <h5 class="mb-0 fw-bold"><i class="bi bi-funnel-fill me-2"></i> Bộ lọc sản phẩm</h5>
        </div>
        <div class="card-body p-4">
            <form id="formSearch" action="@Url.Action("SearchProduct", "Product")" method="get" data-target="searchResult">
                <input type="hidden" name="PageSize" value="@Model.SearchInput.PageSize" />
                <input type="hidden" name="SortOrder" id="hiddenSortOrder" value="@Model.SearchInput.SortOrder" />
                <div class="row g-3 align-items-end">

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Danh mục</label>
                        <select name="CategoryID" class="form-select rounded-pill shadow-sm" style="color: #5a4b4f;" onchange="paginationSearch(null, document.getElementById('formSearch'), 1)">
                            <option value="0">-- Tất cả --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                if (Model.SearchInput.CategoryID == cat.CategoryID)
                                {
                                    <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@cat.CategoryID">@cat.CategoryName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-lg-2 col-md-3 col-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Giá từ</label>
                        <div class="input-group shadow-sm rounded-pill overflow-hidden">
                            <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: #dee2e6;">Từ</span>
                            <input type="text" name="MinPrice" class="form-control border-start-0 money-input" style="border-color: #dee2e6; color: #5a4b4f;" value="@Model.SearchInput.MinPrice" />
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-3 col-6">
                        <label class="form-label fw-bold text-muted small text-uppercase">Đến</label>
                        <div class="input-group shadow-sm rounded-pill overflow-hidden">
                            <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: #dee2e6;">Đến</span>
                            <input type="text" name="MaxPrice" class="form-control border-start-0 money-input" style="border-color: #dee2e6; color: #5a4b4f;" value="@Model.SearchInput.MaxPrice" />
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-8">
                        <label class="form-label fw-bold text-muted small text-uppercase">Từ khóa</label>



                        <input type="text" name="SearchValue" class="form-control rounded-pill shadow-sm" style="color: #5a4b4f;" value="@Model.SearchInput.SearchValue" placeholder="Nhập tên sản phẩm..." />
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <button type="submit" class="btn btn-search-pastel w-100 py-2 shadow-sm" style="height: 42px;">
                            <i class="bi bi-search me-1"></i> Lọc
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <div id="searchResult">
    </div>
</div>

@section Scripts {
    <script>
        // 1. Hàm định dạng tiền tệ (thêm dấu phẩy)
        function formatNumber(n) {
            return n.replace(/\D/g, "").replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        function paginationSearch(e, form, page) {
            if (e) e.preventDefault();

            var actualForm = form || document.getElementById("formSearch") || document.querySelector("form");
            if (!actualForm) {
                alert("Lỗi Dev: Không tìm thấy Form bộ lọc nào trong HTML!");
                return;
            }

            var url = $(actualForm).attr('action') || '@Url.Action("SearchProduct", "Product")';
            var method = $(actualForm).attr('method') || 'GET';
            var targetId = $(actualForm).data('target') || 'searchResult';
            var targetDiv = $('#' + targetId);

            if (targetDiv.length === 0) return;

            // Lấy dữ liệu từ form
            var searchData = $(actualForm).serializeArray();

            // BƯỚC QUAN TRỌNG: Lặp qua mảng dữ liệu, xóa dấu phẩy của MinPrice và MaxPrice trước khi gửi về Server
            searchData.forEach(function(item) {
                if (item.name === "MinPrice" || item.name === "MaxPrice") {
                    item.value = item.value.replace(/,/g, ''); // Xóa tất cả dấu phẩy
                }
            });

            searchData.push({ name: "Page", value: page });

            var currentHeight = targetDiv.height();
            if (currentHeight > 50) {
                targetDiv.css({ 'min-height': currentHeight + 'px', 'opacity': '0.4', 'pointer-events': 'none', 'transition': 'opacity 0.2s ease' });
            } else {
                targetDiv.html('<div class="text-center mt-5"><div class="spinner-border" style="color: #ff7eb3;" role="status"></div><p class="mt-2 text-muted">Đang tải sản phẩm...</p></div>');
            }

            $.ajax({
                url: url,
                type: method,
                data: searchData,
                success: function (result) {
                    targetDiv.css({ 'min-height': 'auto', 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html(result);
                },
                error: function (xhr, status, error) {
                    console.log("Lỗi AJAX:", error);
                    targetDiv.css({ 'min-height': 'auto', 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html('<div class="alert alert-danger mt-4 border-0 shadow-sm">Có lỗi xảy ra khi kết nối Server! Vui lòng F12 xem tab Console.</div>');
                }
            });
        }

        $(document).ready(function () {
            // 2. Định dạng lại ô nhập tiền ngay khi trang tải xong
            $('.money-input').each(function () {
                let val = $(this).val();
                if (val && val !== "0") {
                    $(this).val(formatNumber(val));
                } else if (val === "0") {
                    $(this).val(""); // Nếu giá trị bằng 0 thì xóa trắng cho giao diện đẹp hơn
                }
            });

            // 3. Xử lý sự kiện khi người dùng gõ phím vào ô nhập tiền
            $(document).on('input', '.money-input', function () {
                let cursorPosition = this.selectionStart;
                let originalLength = this.value.length;

                this.value = formatNumber(this.value);

                // Giữ nguyên vị trí con trỏ chuột khi tự động thêm dấu phẩy
                let newLength = this.value.length;
                cursorPosition += newLength - originalLength;
                this.setSelectionRange(cursorPosition, cursorPosition);
            });

            var currentPage = @Model.SearchInput.Page;
            var searchForm = document.getElementById("formSearch") || document.querySelector("form");

            $(searchForm).on('submit', function (e) {
                e.preventDefault();
                paginationSearch(e, this, 1);
            });

            paginationSearch(null, searchForm, currentPage);

            // Nút Thêm vào giỏ hàng
            $(document).on('click', '.add-to-cart', function(e) {
                e.preventDefault();
                e.stopPropagation();

                var btn = $(this);
                var originalHtml = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm"></span>').prop('disabled', true);

                var productId = btn.data('product-id');

                $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: 1 })
                    .done(function(response) {
                        if (response.success) {
                            $('#cartCount').text(response.cartCount);
                            alert('Đã thêm sản phẩm vào giỏ hàng thành công!');
                        } else {
                            alert(response.message || 'Không thể thêm vào giỏ hàng.');
                        }
                    })
                    .fail(function() { alert('Có lỗi xảy ra, vui lòng thử lại'); })
                    .always(function() { btn.html(originalHtml).prop('disabled', false); });
            });
        });
    </script>
}