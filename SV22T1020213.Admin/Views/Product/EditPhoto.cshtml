@model SV22T1020213.Models.Catalog.ProductPhoto
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu ảnh
    </button>
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">Thông tin ảnh mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SavePhoto" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="PhotoID" />
                    <input type="hidden" asp-for="Photo" /> <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Upload Ảnh mới</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <span asp-validation-for="Photo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview"
                                 src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail"
                                 style="max-height:200px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Description" class="form-control" placeholder="Nhập mô tả cho ảnh..." />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   asp-for="DisplayOrder"
                                   class="form-control"
                                   min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       asp-for="IsHidden" />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh này
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>