@model ProductSearchInput

@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">

        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              >

            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">

                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" asp-for="CategoryID" asp-items="await SelectListHelper.Categories()">
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" asp-for="SupplierID" asp-items="await SelectListHelper.Suppliers()">
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>

                    <div class="input-group">
                        <input asp-for="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />

                        <span class="input-group-text">-</span>

                        <input asp-for="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>

                    <div class="input-group">
                        <input asp-for="SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus />

                        <button class="btn btn-info">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>

    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Chạy lần đầu khi load trang
            doSearch(1);
        });

        // Hàm định dạng số có dấu chấm
        function formatNumber(value) {
            value = value.replace(/\D/g, "");
            return value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        // Bắt sự kiện gõ phím để thêm dấu chấm
        document.querySelectorAll(".money-input").forEach(input => {
            input.addEventListener("input", function () {
                let cursorPosition = this.selectionStart;
                let originalLength = this.value.length;

                this.value = formatNumber(this.value);

                let newLength = this.value.length;
                cursorPosition += newLength - originalLength;
                this.setSelectionRange(cursorPosition, cursorPosition);
            });
        });

        // Bắt sự kiện submit của form
        document.getElementById("formSearch").addEventListener("submit", function (e) {
            e.preventDefault(); // Chặn hành vi submit mặc định
            doSearch(1);        // Gọi hàm tìm kiếm từ trang 1
        });

        // Hàm xử lý tìm kiếm
        function doSearch(page) {
            // 1. Xóa dấu chấm của 2 ô input giá trước
            document.querySelectorAll(".money-input").forEach(input => {
                input.value = input.value.replace(/\./g, "");
            });

            // 2. Lấy Form và gọi hàm AJAX phân trang
            var frmSearch = document.getElementById("formSearch");
            paginationSearch(null, frmSearch, page);

            // 3. Phục hồi lại dấu chấm để hiển thị cho người dùng xem
            document.querySelectorAll(".money-input").forEach(input => {
                input.value = formatNumber(input.value);
            });
        }
    </script>
}
