@model ProductAttribute
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu thuộc tính</button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveAttribute">
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="AttributeID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Tên thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeName" class="form-control" autofocus />
                            <span asp-validation-for="AttributeName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Giá trị thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="AttributeValue" class="form-control" />
                            <span asp-validation-for="AttributeValue" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" asp-for="DisplayOrder" class="form-control" min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>