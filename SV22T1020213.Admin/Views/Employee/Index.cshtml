@model PaginationSearchInput
@{
    ViewBag.Title = "Quản lý Nhân viên";
}

@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">

        <form id="formSearch"
              method="get"
              action="~/Employee/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <div class="input-group">
                <input type="hidden" asp-for="PageSize" />

                <input type="text"
                       asp-for="SearchValue"
                       class="form-control"
                       placeholder="Tên nhân viên..." autofocus />

                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}

