@model SV22T1020213.Models.HR.Employee

@{
    ViewData["Title"] = "Thêm nhân viên";
}

<h2>Thêm nhân viên</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label>Họ tên</label>
        <input asp-for="FullName" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Ngày sinh</label>
        <input asp-for="BirthDate" type="date" class="form-control" />
    </div>
    <div class="form-group">
        <label>Địa chỉ</label>
        <input asp-for="Address" class="form-control" />
    </div>
    <div class="form-group">
        <label>Phone</label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" required />
    </div>
   
    <div class="form-group">
        <label>Ảnh</label>
        <input type="file" name="PhotoFile" class="form-control" /> <!-- Giả sử xử lý upload ở Controller -->
    </div>
    <div class="form-group">
        <label>Đang làm việc</label>
        <input asp-for="IsWorking" type="checkbox" />
    </div>
   
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@Html.ValidationSummary()