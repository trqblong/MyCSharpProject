@model OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button"
                class="btn btn-primary dropdown-toggle"
                data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i>
            Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            @* <li><a class="dropdown-item open-modal" href="~/Order/Accept/123">Duyệt đơn hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Shipping/123">Chuyển giao hàng</a></li>
            <li><a class="dropdown-item open-modal" href="~/Order/Finish/123">Hoàn tất đơn hàng</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/123">Hủy đơn hàng</a></li>
            <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/123">Từ chối đơn hàng</a></li> *@
            @if (Model.Status == OrderStatusEnum.New)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
            }

            @if (Model.Status == OrderStatusEnum.Accepted)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
            }

            @if (Model.Status == OrderStatusEnum.Shipping)
            {
                <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
            }

            @if (Model.Status != OrderStatusEnum.Completed && Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected)
            {
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
            }
        </ul>
    </div>

    @if (Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

@{
    var alertClass = Model.Status switch
    {
        OrderStatusEnum.New => "alert-warning",
        OrderStatusEnum.Accepted => "alert-primary",
        OrderStatusEnum.Shipping => "alert-info",
        OrderStatusEnum.Completed => "alert-success",
        OrderStatusEnum.Cancelled => "alert-secondary",
        OrderStatusEnum.Rejected => "alert-danger",
        _ => "alert-secondary"
    };

    var iconClass = Model.Status switch
    {
        OrderStatusEnum.Completed => "bi-check-circle-fill",
        OrderStatusEnum.Cancelled or OrderStatusEnum.Rejected => "bi-x-circle-fill",
        _ => "bi-info-circle-fill"
    };
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
<div class="alert alert-success d-flex align-items-center mb-3">
    <i class="bi bi-check-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Status.GetDescription()
        @if (Model.FinishedTime.HasValue)
        {
            <span> lúc <b>@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></span>
        }
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.EmployeeName) ? "Chưa có" : Model.EmployeeName)</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = 1;
                    decimal total = 0;
                    var details = ViewBag.Details as List<OrderDetailViewInfo>;
                }
                @if (details != null)
                {
                    foreach (var item in details)
                    {
                        total += item.TotalPrice;
                        <tr>
                            <td class="text-center">@(stt++)</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-end">
                                @if (Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted)
                                {
                                    <a href="~/Order/EditDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary open-modal">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Order/DeleteDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-danger open-modal">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@total.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}