@model PagedResult<Product>

@{
    Layout = null;
}

@foreach (var item in Model.DataItems)
{
    <form method="post"
          class="border rounded p-2 mb-2"
          onsubmit="addCartItem(event, this)">

        <strong>@item.ProductName</strong>
        <input type="hidden" name="productID" value="@item.ProductID" />

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                     class="img-fluid border" style="max-height:100px" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input class="form-control form-control-sm text-end"
                               name="salePrice"
                               value="@item.Price.ToString("0.##")" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number"
                               name="quantity"
                               min="1"
                               value="1"
                               class="form-control form-control-sm text-end" />
                    </div>
                </div>

                <button class="btn btn-sm btn-primary mt-2 w-100">
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}

@if (Model.PageCount > 1)
{
    int current = Model.Page;
    int total = Model.PageCount;

    // Tính toán start và end cho các trang ở giữa (+/- 2 trang quanh trang hiện tại)
    int start = Math.Max(2, current - 2);
    int end = Math.Min(total - 1, current + 2);

    <ul class="pagination justify-content-center mb-0 mt-2">

        <li class="page-item @(current == 1 ? "disabled" : "")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearch'), @(current - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        <li class="page-item @(current == 1 ? "active" : "")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearch'), 1)">
                1
            </a>
        </li>

        @if (start > 2)
        {
            <li class="page-item disabled"><span class="page-link">...</span></li>
        }

        @for (int i = start; i <= end; i++)
        {
            <li class="page-item @(i == current ? "active" : "")">
                <a class="page-link" href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearch'), @i)">
                    @i
                </a>
            </li>
        }

        @if (end < total - 1)
        {
            <li class="page-item disabled"><span class="page-link">...</span></li>
        }

        @if (total > 1)
        {
            <li class="page-item @(current == total ? "active" : "")">
                <a class="page-link" href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearch'), @total)">
                    @total
                </a>
            </li>
        }

        <li class="page-item @(current == total ? "disabled" : "")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearch'), @(current + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>

    </ul>
}