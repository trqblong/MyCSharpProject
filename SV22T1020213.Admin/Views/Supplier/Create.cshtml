@model SV22T1020213.Models.Partner.Supplier

@{
    ViewBag.Title = "Thêm nhà cung cấp";
}

<h4 class="mb-3">
    <i class="bi bi-plus-circle"></i>
    Thêm nhà cung cấp mới
</h4>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">

                <!-- Tên nhà cung cấp -->
                <div class="col-md-6">
                    <label asp-for="SupplierName" class="form-label">
                        Tên nhà cung cấp
                    </label>
                    <input asp-for="SupplierName" class="form-control" />
                    <span asp-validation-for="SupplierName" class="text-danger"></span>
                </div>

                <!-- Tên giao dịch -->
                <div class="col-md-6">
                    <label asp-for="ContactName" class="form-label">
                        Tên giao dịch
                    </label>
                    <input asp-for="ContactName" class="form-control" />
                    <span asp-validation-for="ContactName" class="text-danger"></span>
                </div>

                <!-- Điện thoại -->
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label">
                        Điện thoại
                    </label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">
                        Email
                    </label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Địa chỉ -->
                <div class="col-md-12">
                    <label asp-for="Address" class="form-label">
                        Địa chỉ
                    </label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <!-- Tỉnh / Thành -->
                <div class="col-md-6">
                    <label asp-for="Province" class="form-label">
                        Tỉnh / Thành
                    </label>
                    <input asp-for="Province" class="form-control" />
                    <span asp-validation-for="Province" class="text-danger"></span>
                </div>

            </div>

            <!-- Nút -->
            <div class="mt-4 text-end">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Quay lại
                </a>

                <button type="submit" class="btn btn-success ms-2">
                    <i class="bi bi-save"></i>
                    Lưu dữ liệu
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
